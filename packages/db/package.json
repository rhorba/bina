{
  "name": "@bina/db",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": "./src/index.ts",
    "./schema": "./src/schema/index.ts",
    "./client": "./src/client.ts",
    "./seed": "./src/seed.ts"
  },
  "scripts": {
    "push": "tsx node_modules/drizzle-kit/bin.cjs push",
    "migrate": "tsx node_modules/drizzle-kit/bin.cjs migrate",
    "generate": "tsx node_modules/drizzle-kit/bin.cjs generate",
    "studio": "tsx node_modules/drizzle-kit/bin.cjs studio",
    "rls": "tsx src/apply-rls.ts",
    "seed": "tsx src/seed.ts",
    "setup": "pnpm migrate && pnpm rls && pnpm seed",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@bina/core": "workspace:*",
    "argon2": "^0.41.1",
    "drizzle-orm": "^0.38.3",
    "postgres": "^3.4.5"
  },
  "devDependencies": {
    "@types/node": "^22.10.2",
    "drizzle-kit": "^0.30.1",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
