# Database
DATABASE_URL="postgresql://bina_app:bina_secret@localhost:5432/bina"
DATABASE_DIRECT_URL="postgresql://postgres:postgres@localhost:5432/bina"

# Auth.js v5
AUTH_SECRET="generate-with-openssl-rand-base64-32"
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""
AUTH_URL="http://localhost:3000"

# Cloudflare R2 (compliance docs — private bucket)
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_PRIVATE_BUCKET="bina-compliance"
R2_PUBLIC_BUCKET="bina-public"
R2_PUBLIC_URL="https://pub.bina.ma"

# Resend (email alerts). In test mode use onboarding@resend.dev (delivers only to
# the Resend account owner); in prod use a verified domain sender.
RESEND_API_KEY=""
RESEND_FROM_EMAIL="Bina <onboarding@resend.dev>"

# App
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"
